# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for OAuth redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# LINE Messaging API (optional) — internal team notifications.
# Preferred: set Channel ID + Secret to auto-mint stateless tokens. The secret also verifies webhooks.
# Fallback: a long-lived LINE_CHANNEL_ACCESS_TOKEN. LINE_DEFAULT_TARGET_ID is the catch-all group/user.
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_DEFAULT_TARGET_ID=

# Email via Resend (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Recipient for internal system notification fallback emails
NOTIFICATION_EMAIL=

# First admin email (for documentation reference only)
FIRST_ADMIN_EMAIL=your@email.com

# Odoo (read-only sale-order sync, optional) — all four required for sync to run.
# Note: the username is the Odoo login email; the variable is ODOO_USERNAME.
ODOO_URL=https://yourcompany.odoo.com
ODOO_DB=your-odoo-database
ODOO_USERNAME=you@yourdomain.com
ODOO_API_KEY=your-odoo-api-key
